//@version=5
indicator("S&P500 First 15min vs EOD Direction",
     shorttitle    = "15min/EOD Tracker",
     overlay       = true,
     max_bars_back = 5000)

// ──────────────────────────────────────────────────────────────────────────────
// Inputs — General
// ──────────────────────────────────────────────────────────────────────────────
string i_session = input.string("0930-1600", "Session (HH:MM-HH:MM)",
     tooltip = "NYSE regular hours. For CME ES futures RTH use 0930-1600 ET or adjust per broker.",
     group = "General")
string i_days    = input.string("23456", "Trading Days  (1=Sun … 7=Sat)",
     tooltip = "23456 = Monday – Friday",
     group = "General")
bool   i_hlBar   = input.bool(true, "Highlight first 15-min bar on chart",  group = "General")
bool   i_labels  = input.bool(true, "Show EOD agreement labels on last bar of day", group = "General")
string i_tblPos  = input.string("Top Right", "Table position",
     options = ["Top Right","Top Left","Bottom Right","Bottom Left","Middle Right","Middle Left"],
     group = "General")

// ──────────────────────────────────────────────────────────────────────────────
// Inputs — Custom Window
// ──────────────────────────────────────────────────────────────────────────────
int  i_customMins = input.int(30, "Custom window (minutes)", minval = 1, maxval = 480,
     tooltip = "Minutes from session open for the second measurement window.\n" +
               "On a 15-min chart the window snaps to the last complete bar " +
               "that starts within N minutes (e.g. 20 min → uses the 9:45 bar close on a 15-min chart).",
     group = "Custom Window")
bool i_showCustom = input.bool(true, "Show custom window section in table",
     group = "Custom Window")

// ──────────────────────────────────────────────────────────────────────────────
// Inputs — Table Appearance
// ──────────────────────────────────────────────────────────────────────────────
string i_fontSize    = input.string("Small", "Font size",
     options = ["Tiny","Small","Normal","Large","Huge"],
     group = "Table Appearance")
color  i_tblBg       = input.color(color.new(color.black, 72), "Table background",   group = "Table Appearance")
color  i_borderClr   = input.color(color.new(color.gray,  60), "Border colour",      group = "Table Appearance")
color  i_hdrBg       = input.color(color.new(color.blue,  38), "Header background",  group = "Table Appearance")
color  i_hdrTxt      = input.color(color.white,                "Header text",        group = "Table Appearance")
color  i_labelTxt    = input.color(color.silver,               "Row label text",     group = "Table Appearance")
color  i_valueTxt    = input.color(color.white,                "Row value text",     group = "Table Appearance")
color  i_agreeClr    = input.color(color.lime,                 "Agree / Bullish",    group = "Table Appearance")
color  i_bearBearClr = input.color(color.orange,               "Bear → Bear",        group = "Table Appearance")
color  i_disagreeClr = input.color(color.red,                  "Disagree / Bearish", group = "Table Appearance")

// ──────────────────────────────────────────────────────────────────────────────
// Derived style values
// ──────────────────────────────────────────────────────────────────────────────
string tblPos =
     i_tblPos == "Top Left"     ? position.top_left     :
     i_tblPos == "Bottom Right" ? position.bottom_right :
     i_tblPos == "Bottom Left"  ? position.bottom_left  :
     i_tblPos == "Middle Right" ? position.middle_right :
     i_tblPos == "Middle Left"  ? position.middle_left  :
     position.top_right

string tblFontSize =
     i_fontSize == "Tiny"   ? size.tiny   :
     i_fontSize == "Normal" ? size.normal :
     i_fontSize == "Large"  ? size.large  :
     i_fontSize == "Huge"   ? size.huge   :
     size.small

// ──────────────────────────────────────────────────────────────────────────────
// Helper: format count + percentage
// ──────────────────────────────────────────────────────────────────────────────
pctStr(int n, float base) =>
    str.tostring(n) + "  (" + str.tostring(math.round(n / base * 1000) / 10.0, "#.#") + "%)"

// ──────────────────────────────────────────────────────────────────────────────
// Session detection
// ──────────────────────────────────────────────────────────────────────────────
string SESSION  = i_session + ":" + i_days
bool inSess     = not na(time(timeframe.period, SESSION))
bool inSessPrev = not na(time(timeframe.period, SESSION)[1])
bool sessStart  = inSess and not inSessPrev   // first bar of session
bool sessEnd    = not inSess and inSessPrev   // first bar after session; close[1] = EOD close

// ──────────────────────────────────────────────────────────────────────────────
// Per-session state — fixed 15-min window
// ──────────────────────────────────────────────────────────────────────────────
var float  f15Open  = na
var float  f15Close = na
var float  dayOpen  = na       // session open price (shared reference for both windows)
var bool   hasDay   = false
var string today15  = "—"

// Per-session state — custom window
var int    sessStartMs  = na   // timestamp (ms) when session opened
var float  custWinClose = na   // close of the last bar inside the custom window
var bool   custWinSet   = false
var string todayCustom  = "—"

if sessStart
    f15Open      := open
    f15Close     := close
    dayOpen      := open
    hasDay       := true
    today15      := close > open ? "Bullish ↑" : close < open ? "Bearish ↓" : "Neutral →"
    sessStartMs  := time
    custWinClose := na
    custWinSet   := false

// Custom window closes on the first bar whose open time ≥ session open + N minutes.
// close[1] is then the close of the last bar that started within the window.
bool custWinEnd = not na(sessStartMs) and not custWinSet and not sessStart and inSess and
                  (time - sessStartMs) >= i_customMins * 60 * 1000

if custWinEnd
    custWinClose := close[1]
    custWinSet   := true
    todayCustom  := close[1] > dayOpen ? "Bullish ↑" : close[1] < dayOpen ? "Bearish ↓" : "Neutral →"

// ──────────────────────────────────────────────────────────────────────────────
// Metrics — fixed 15-min window
// ──────────────────────────────────────────────────────────────────────────────
var int nDays     = 0
var int nAgree    = 0
var int nDisag    = 0
var int nBullBull = 0
var int nBearBear = 0
var int nBullBear = 0
var int nBearBull = 0

// Metrics — custom window
var int nCDays     = 0
var int nCAgree    = 0
var int nCDisag    = 0
var int nCBullBull = 0
var int nCBearBear = 0
var int nCBullBear = 0
var int nCBearBull = 0

if sessEnd and hasDay
    bool f15Bull  = f15Close > f15Open
    bool eodBull  = close[1] > dayOpen
    bool agree15  = f15Bull == eodBull

    // 15-min metrics
    nDays += 1
    if agree15
        nAgree    += 1
        nBullBull += f15Bull ? 1 : 0
        nBearBear += f15Bull ? 0 : 1
    else
        nDisag    += 1
        nBullBear += f15Bull ? 1 : 0
        nBearBull += f15Bull ? 0 : 1

    // Custom window metrics (only when window closed before EOD)
    if custWinSet
        bool custBull = custWinClose > dayOpen
        bool agreeC   = custBull == eodBull

        nCDays += 1
        if agreeC
            nCAgree    += 1
            nCBullBull += custBull ? 1 : 0
            nCBearBear += custBull ? 0 : 1
        else
            nCDisag    += 1
            nCBullBear += custBull ? 1 : 0
            nCBearBull += custBull ? 0 : 1

    // EOD label — symbol reflects 15-min result; tooltip includes custom window
    if i_labels
        string custTip = custWinSet ?
             "\n" + str.tostring(i_customMins) + "min: " +
             (custWinClose > dayOpen ? "Bull ↑" : "Bear ↓") + "  →  EOD: " +
             (eodBull ? "Bull ↑" : "Bear ↓") + "  " +
             ((custWinClose > dayOpen) == eodBull ? "✓" : "✗") : ""

        label.new(
             x         = bar_index[1],
             y         = high[1],
             text      = agree15 ? "✓" : "✗",
             style     = label.style_label_down,
             color     = agree15 ? color.new(color.green, 35) : color.new(color.red, 35),
             textcolor = color.white,
             size      = size.normal,
             tooltip   = "15min: " + (f15Bull ? "Bull ↑" : "Bear ↓") +
                         "  →  EOD: " + (eodBull ? "Bull ↑" : "Bear ↓") +
                         "  " + (agree15 ? "✓" : "✗") + custTip)

    hasDay := false

// ──────────────────────────────────────────────────────────────────────────────
// Background: highlight the first 15-min bar
// ──────────────────────────────────────────────────────────────────────────────
bgcolor(i_hlBar and sessStart ? color.new(color.blue, 87) : na,
     title = "First 15-min bar highlight")

// ──────────────────────────────────────────────────────────────────────────────
// Metrics table
// 11 rows for 15-min section; +12 rows for custom section when visible
// ──────────────────────────────────────────────────────────────────────────────
var table T = table.new(tblPos, 2, i_showCustom ? 23 : 11,
     bgcolor      = i_tblBg,
     border_width = 1,
     border_color = i_borderClr)

// Shorthand for filling a single cell
tCell(int col, int row, string txt, color tc) =>
    table.cell(T, col, row, txt, text_color = tc, bgcolor = i_tblBg, text_size = tblFontSize)

tCellHdr(int col, int row, string txt) =>
    table.cell(T, col, row, txt, text_color = i_hdrTxt, bgcolor = i_hdrBg, text_size = tblFontSize)

tCellSep(int col, int row) =>
    table.cell(T, col, row, "───────────────────", text_color = i_borderClr, bgcolor = i_tblBg, text_size = size.tiny)

if barstate.islast
    float td  = math.max(nDays,  1)
    float tdc = math.max(nCDays, 1)

    // ── 15-min section ────────────────────────────────────────────────────────
    // Row 0: header
    tCellHdr(0, 0, "First 15min Window")
    tCellHdr(1, 0, "Count  (Rate)")

    // Row 1: today's 15-min direction
    tCell(0, 1, "Today – First 15min", i_labelTxt)
    tCell(1, 1, today15,
         today15 == "Bullish ↑" ? i_agreeClr :
         today15 == "Bearish ↓" ? i_disagreeClr : color.gray)

    // Row 2: separator
    tCellSep(0, 2)
    tCellSep(1, 2)

    // Row 3: total
    tCell(0, 3, "Total Days Tracked",         i_labelTxt)
    tCell(1, 3, str.tostring(nDays),           i_valueTxt)

    // Row 4: agree
    tCell(0, 4, "✓  Direction Agreed",        i_agreeClr)
    tCell(1, 4, pctStr(nAgree, td),            i_agreeClr)

    // Row 5: disagree
    tCell(0, 5, "✗  Direction Disagreed",     i_disagreeClr)
    tCell(1, 5, pctStr(nDisag, td),            i_disagreeClr)

    // Row 6: separator
    tCellSep(0, 6)
    tCellSep(1, 6)

    // Row 7: bull → bull
    tCell(0, 7, "↑ 15min Bull  →  EOD Bull",  i_agreeClr)
    tCell(1, 7, pctStr(nBullBull, td),          i_agreeClr)

    // Row 8: bear → bear
    tCell(0, 8, "↓ 15min Bear  →  EOD Bear",  i_bearBearClr)
    tCell(1, 8, pctStr(nBearBear, td),          i_bearBearClr)

    // Row 9: bull → bear
    tCell(0, 9, "↑ 15min Bull  →  EOD Bear",  i_disagreeClr)
    tCell(1, 9, pctStr(nBullBear, td),          i_disagreeClr)

    // Row 10: bear → bull
    tCell(0, 10, "↓ 15min Bear  →  EOD Bull", i_disagreeClr)
    tCell(1, 10, pctStr(nBearBull, td),         i_disagreeClr)

    // ── Custom window section ─────────────────────────────────────────────────
    if i_showCustom
        string customLabel = str.tostring(i_customMins) + "min Window"

        // Row 11: thick divider
        table.cell(T, 0, 11, "═══════════════════", text_color = i_borderClr, bgcolor = i_tblBg, text_size = size.tiny)
        table.cell(T, 1, 11, "═══════════════════", text_color = i_borderClr, bgcolor = i_tblBg, text_size = size.tiny)

        // Row 12: header
        tCellHdr(0, 12, "First " + customLabel)
        tCellHdr(1, 12, "Count  (Rate)")

        // Row 13: today's custom direction
        tCell(0, 13, "Today – First " + customLabel, i_labelTxt)
        tCell(1, 13, todayCustom,
             todayCustom == "Bullish ↑" ? i_agreeClr :
             todayCustom == "Bearish ↓" ? i_disagreeClr : color.gray)

        // Row 14: separator
        tCellSep(0, 14)
        tCellSep(1, 14)

        // Row 15: total
        tCell(0, 15, "Total Days Tracked",           i_labelTxt)
        tCell(1, 15, str.tostring(nCDays),            i_valueTxt)

        // Row 16: agree
        tCell(0, 16, "✓  Direction Agreed",          i_agreeClr)
        tCell(1, 16, pctStr(nCAgree, tdc),            i_agreeClr)

        // Row 17: disagree
        tCell(0, 17, "✗  Direction Disagreed",       i_disagreeClr)
        tCell(1, 17, pctStr(nCDisag, tdc),            i_disagreeClr)

        // Row 18: separator
        tCellSep(0, 18)
        tCellSep(1, 18)

        // Row 19: bull → bull
        tCell(0, 19, "↑ " + customLabel + " Bull  →  EOD Bull",  i_agreeClr)
        tCell(1, 19, pctStr(nCBullBull, tdc),                     i_agreeClr)

        // Row 20: bear → bear
        tCell(0, 20, "↓ " + customLabel + " Bear  →  EOD Bear",  i_bearBearClr)
        tCell(1, 20, pctStr(nCBearBear, tdc),                     i_bearBearClr)

        // Row 21: bull → bear
        tCell(0, 21, "↑ " + customLabel + " Bull  →  EOD Bear",  i_disagreeClr)
        tCell(1, 21, pctStr(nCBullBear, tdc),                     i_disagreeClr)

        // Row 22: bear → bull
        tCell(0, 22, "↓ " + customLabel + " Bear  →  EOD Bull",  i_disagreeClr)
        tCell(1, 22, pctStr(nCBearBull, tdc),                     i_disagreeClr)

// ──────────────────────────────────────────────────────────────────────────────
// Timeframe warning
// ──────────────────────────────────────────────────────────────────────────────
if barstate.islast and timeframe.period != "15"
    label.new(bar_index, high,
         "⚠  This indicator is designed for the 15-minute chart.\n" +
         "Current timeframe: " + timeframe.period + " min",
         style     = label.style_label_left,
         color     = color.new(color.red, 20),
         textcolor = color.white,
         size      = size.normal)

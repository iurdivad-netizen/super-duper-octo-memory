// THIS INDICATOR ONLY WORKS FOR THE SPX CHART
//
// It measures the expected move of SPX for the selected chart timeframe based on
// the current value of the VIX index and plots that expected move as an
// upper/lower band.
//
// Expected move = currentVIX / sqrt(periods-per-year):
//   Daily   -> sqrt(252)  (trading sessions/year)
//   Weekly  -> sqrt(52)   (weeks/year)
//   Monthly -> sqrt(12)   (months/year)
//   Intraday-> sqrt(ticks/year) for the chart's tf
//
// Strategy modeled: PUT CREDIT SPREAD.
// At the close of each period the short put is placed BELOW the lower edge of
// the expected-move band (an optional extra offset pushes it further out of the
// money). The trade is resolved on the following period's close:
//   WIN  -> price closes ABOVE the short-put strike  (spread expires worthless,
//           seller keeps the credit)
//   LOSS -> price closes AT or BELOW the short-put strike (spread is breached)
// The counter table tallies wins / losses / win-rate so the VIX-implied range
// can be backtested as a put-credit-spread location rule.

//@version=5

indicator(title="Expected SPX Movement by timeframe", shorttitle="SPX Exp Move (VIX)", overlay=true)

// ──────────────────────────────────────────────────────────────────────────────
// Inputs
// ──────────────────────────────────────────────────────────────────────────────
string i_offsetMode  = input.string("% of price", "Distance to lower band",
     options = ["% of price", "Points", "At lower band"],
     tooltip = "How far BELOW the lower expected-move band to place the short put. 'At lower band' ignores the values below.",
     group = "Put Credit Spread")
float  i_offsetPct   = input.float(0.0, "  ↳ distance (% of price)",
     minval = 0.0, step = 0.05,
     tooltip = "Used when distance mode = '% of price'.",
     group = "Put Credit Spread")
float  i_offsetPts   = input.float(10.0, "  ↳ distance (points)",
     minval = 0.0, step = 1.0,
     tooltip = "Used when distance mode = 'Points'.",
     group = "Put Credit Spread")
bool   i_showStrike  = input.bool(true,  "Plot short-put strike line", group = "Put Credit Spread")
bool   i_showTrades  = input.bool(true,  "Plot resolved trades (win/loss markers)",
     group = "Put Credit Spread")
int    i_drift       = input.int(1, "Hold / resolution drift (bars)",
     minval = 1, maxval = 20,
     tooltip = "How many periods the spread is held before it is resolved on close. 1 = next bar (loosest, highest win rate). Increase to stress-test: the strike is set N bars ago and price has had N periods to drift below it, which lowers the win rate toward something more realistic.",
     group = "Put Credit Spread")
bool   i_projectFwd  = input.bool(true, "Project range/strike to its resolution bar",
     tooltip = "Shifts the band and short-put strike forward by the drift so the level drawn over a bar is exactly the one that bar's close is tested against. Makes trade resolutions visually verifiable.",
     group = "Put Credit Spread")
bool   i_showCounter = input.bool(true,  "Show win/loss counter table",           group = "Counter")
string i_tblPos      = input.string("Top Right", "Counter table position",
     options = ["Top Right","Top Left","Bottom Right","Bottom Left","Middle Right","Middle Left"],
     group = "Counter")
int    i_lookback    = input.int(0, "Counter lookback (bars, 0 = all history)",
     minval = 0,
     tooltip = "0 counts every confirmed bar on the chart. A positive value only counts the most recent N bars.",
     group = "Counter")
color  i_bandColor   = input.color(#ffffff, "Band color", group = "Style")

print(txt) =>
    var lbl = label.new(bar_index, na, txt, xloc.bar_index, yloc.price, color(na), label.style_none, color.gray, size.large, text.align_left)
    label.set_xy(lbl, bar_index, ta.highest(10)[1])
    label.set_text(lbl, txt)

// ──────────────────────────────────────────────────────────────────────────────
// Expected move from VIX
// ──────────────────────────────────────────────────────────────────────────────
vixData = request.security("CBOE:VIX", timeframe.period, close)

scaleFreq = if timeframe.period == "D"
    math.sqrt(252)
else if timeframe.period == "W"
    math.sqrt(52)
else if timeframe.period == "M"
    math.sqrt(12)
else if timeframe.period == "15"
    math.sqrt(6552)
else if timeframe.period == "60"
    math.sqrt(1638)
else if timeframe.period == "120"
    math.sqrt(819)
else if timeframe.period == "240"
    math.sqrt(409)
else
    math.sqrt(252)

probPercMove = vixData / scaleFreq

changeUpper = close + (close * (probPercMove / 100))
changeLower = close - (close * (probPercMove / 100))

int projOff = i_projectFwd ? i_drift : 0

p1 = plot(changeUpper, 'Probable Upper Level', i_bandColor, offset = projOff)
p2 = plot(changeLower, 'Probable Lower Level', i_bandColor, offset = projOff)
fill(p1, p2, color = color.new(i_bandColor, 90))

// Put-credit-spread short strike: lower band pushed further out of the money
offsetDist = i_offsetMode == "Points"   ? i_offsetPts :
             i_offsetMode == "% of price" ? close * (i_offsetPct / 100) : 0.0
shortPutStrike = changeLower - offsetDist
plot(i_showStrike ? shortPutStrike : na, 'Short Put Strike', color.new(color.red, 0),
     style = plot.style_linebr, offset = projOff)

// Resolve the spread against the strike set i_drift periods ago.
strikeAtEntry = shortPutStrike[i_drift]
pcsWin  = close >  strikeAtEntry
pcsLoss = close <= strikeAtEntry

plotshape(i_showTrades and pcsWin  and barstate.isconfirmed, title = "PCS win",
     style = shape.triangleup,   location = location.belowbar,
     color = color.new(color.green, 0), size = size.tiny)
plotshape(i_showTrades and pcsLoss and barstate.isconfirmed, title = "PCS loss",
     style = shape.flag,         location = location.belowbar,
     color = color.rgb(188, 76, 76), size = size.small)

// ──────────────────────────────────────────────────────────────────────────────
// Put-credit-spread win/loss counter
// A "trade" = one resolved period that had a valid prior-bar strike to test.
// win  -> close above the short-put strike (spread expires worthless)
// loss -> close at/below the short-put strike (spread breached)
// ──────────────────────────────────────────────────────────────────────────────
var int cTotal = 0
var int cWin   = 0

withinLookback = i_lookback == 0 or (bar_index >= (last_bar_index - i_lookback + 1))
testable       = barstate.isconfirmed and not na(strikeAtEntry) and withinLookback

if testable
    cTotal += 1
    if pcsWin
        cWin += 1

cLoss   = cTotal - cWin
hitRate = cTotal > 0 ? (cWin / cTotal) * 100 : 0.0

// ──────────────────────────────────────────────────────────────────────────────
// Counter table
// ──────────────────────────────────────────────────────────────────────────────
tblPosition(p) =>
    p == "Top Right"     ? position.top_right    :
     p == "Top Left"     ? position.top_left     :
     p == "Bottom Right" ? position.bottom_right :
     p == "Bottom Left"  ? position.bottom_left  :
     p == "Middle Right" ? position.middle_right : position.middle_left

var table t = table.new(tblPosition(i_tblPos), 2, 5,
     border_width = 1, frame_color = color.gray, frame_width = 1)

if i_showCounter and barstate.islast
    table.cell(t, 0, 0, "Put Credit Spread", text_color = color.white, bgcolor = color.new(color.blue, 30), text_size = size.normal)
    table.cell(t, 1, 0, str.tostring(timeframe.period), text_color = color.white, bgcolor = color.new(color.blue, 30), text_size = size.normal)

    table.cell(t, 0, 1, "Trades tested", text_color = color.white, bgcolor = color.new(color.gray, 60))
    table.cell(t, 1, 1, str.tostring(cTotal), text_color = color.white, bgcolor = color.new(color.gray, 60))

    table.cell(t, 0, 2, "Wins (close > strike)", text_color = color.white, bgcolor = color.new(color.green, 50))
    table.cell(t, 1, 2, str.tostring(cWin), text_color = color.white, bgcolor = color.new(color.green, 50))

    table.cell(t, 0, 3, "Losses (close <= strike)", text_color = color.white, bgcolor = color.new(color.red, 50))
    table.cell(t, 1, 3, str.tostring(cLoss), text_color = color.white, bgcolor = color.new(color.red, 50))

    table.cell(t, 0, 4, "Win rate", text_color = color.white, bgcolor = color.new(color.gray, 30))
    table.cell(t, 1, 4, str.tostring(hitRate, "#.##") + " %", text_color = color.white, bgcolor = color.new(color.gray, 30))

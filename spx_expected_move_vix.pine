// THIS INDICATOR ONLY WORKS FOR THE SPX CHART
//
// It measures the expected move of SPX for the selected chart timeframe based on
// the current value of the VIX index and plots that expected move as an
// upper/lower band.
//
// Expected move = currentVIX / sqrt(periods-per-year):
//   Daily   -> sqrt(252)  (trading sessions/year)
//   Weekly  -> sqrt(52)   (weeks/year)
//   Monthly -> sqrt(12)   (months/year)
//   Intraday-> sqrt(ticks/year) for the chart's tf
//
// Strategy modeled: PUT CREDIT SPREAD (+ mirror CALL CREDIT SPREAD).
// A trade is opened at a bar's close with a FIXED strike anchored to that
// close. The expected move is scaled to the holding horizon
// (per-period VIX move x sqrt(holding bars)). The short put sits that move
// (plus optional offset) BELOW the entry close; the short call that move ABOVE.
// "Open a trade every bar" ON  -> a new trade is entered each bar and held the
//   tenor (overlapping; e.g. DAILY chart + tenor 5 = a ~1-week trade every day).
// "Open a trade every bar" OFF -> non-overlapping, one trade rolled at expiry.
// Either way the position is held i_drift bars and resolved at expiry against
// its fixed entry strike.
//   PCS WIN  -> exit close ABOVE the fixed short-put strike  (keeps credit)
//   PCS LOSS -> exit close AT/BELOW the fixed short-put strike
//   CCS WIN  -> exit close BELOW the fixed short-call strike
//   CCS LOSS -> exit close AT/ABOVE the fixed short-call strike
// The counter tallies wins / losses / win-rate for both spreads side by side
// (run both together for an iron-condor view). The strike is locked at entry
// and drawn flat for the trade's life so it no longer re-centers on price.

//@version=5

indicator(title="Expected SPX Movement by timeframe", shorttitle="SPX Exp Move (VIX)", overlay=true)

// ──────────────────────────────────────────────────────────────────────────────
// Inputs
// ──────────────────────────────────────────────────────────────────────────────
string i_offsetMode  = input.string("% of price", "Distance to lower band",
     options = ["% of price", "Points", "At lower band"],
     tooltip = "How far BELOW the lower expected-move band to place the short put. 'At lower band' ignores the values below.",
     group = "Put Credit Spread")
float  i_offsetPct   = input.float(0.0, "  ↳ distance (% of price)",
     minval = 0.0, step = 0.05,
     tooltip = "Used when distance mode = '% of price'.",
     group = "Put Credit Spread")
float  i_offsetPts   = input.float(10.0, "  ↳ distance (points)",
     minval = 0.0, step = 1.0,
     tooltip = "Used when distance mode = 'Points'.",
     group = "Put Credit Spread")
bool   i_showStrike  = input.bool(true,  "Plot short-put strike line", group = "Put Credit Spread")
bool   i_showTrades  = input.bool(true,  "Plot resolved trades (win/loss markers)",
     group = "Put Credit Spread")
int    i_drift       = input.int(1, "Option tenor / holding period (bars)",
     minval = 1, maxval = 20,
     tooltip = "How many bars the spread is held before it expires and is resolved on close. On a WEEKLY chart, 1 = a 7DTE trade opened every weekly bar and rolled at expiry. The expected move is scaled to this horizon (per-bar VIX move x sqrt(tenor)).",
     group = "Put Credit Spread")
bool   i_everyBar    = input.bool(true, "Open a trade every bar (overlapping)",
     tooltip = "ON: a new trade is opened on every bar and held for the tenor, so trades overlap (e.g. DAILY chart + tenor 5 = a fresh ~1-week trade entered every day). OFF: non-overlapping, one trade at a time rolled at expiry (independent samples, fewer trades).",
     group = "Put Credit Spread")
bool   i_projectFwd  = input.bool(true, "Project range/strike to its resolution bar",
     tooltip = "Shifts the band and short-put strike forward by the drift so the level drawn over a bar is exactly the one that bar's close is tested against. Makes trade resolutions visually verifiable.",
     group = "Put Credit Spread")
bool   i_ccsEnable   = input.bool(true, "Enable Call Credit Spread",
     tooltip = "Short call placed ABOVE the upper expected-move band. Win = period closes BELOW the short-call strike.",
     group = "Call Credit Spread")
string i_cOffsetMode = input.string("% of price", "Distance to upper band",
     options = ["% of price", "Points", "At upper band"],
     tooltip = "How far ABOVE the upper expected-move band to place the short call. 'At upper band' ignores the values below.",
     group = "Call Credit Spread")
float  i_cOffsetPct  = input.float(0.0, "  ↳ distance (% of price)",
     minval = 0.0, step = 0.05, tooltip = "Used when distance mode = '% of price'.",
     group = "Call Credit Spread")
float  i_cOffsetPts  = input.float(10.0, "  ↳ distance (points)",
     minval = 0.0, step = 1.0, tooltip = "Used when distance mode = 'Points'.",
     group = "Call Credit Spread")
bool   i_cShowStrike = input.bool(true,  "Plot short-call strike line", group = "Call Credit Spread")
bool   i_cShowTrades = input.bool(true,  "Plot resolved trades (win/loss markers)",
     group = "Call Credit Spread")
bool   i_showCounter = input.bool(true,  "Show win/loss counter table",           group = "Counter")
string i_tblPos      = input.string("Top Right", "Counter table position",
     options = ["Top Right","Top Left","Bottom Right","Bottom Left","Middle Right","Middle Left"],
     group = "Counter")
int    i_lookback    = input.int(0, "Counter lookback (bars, 0 = all history)",
     minval = 0,
     tooltip = "0 counts every confirmed bar on the chart. A positive value only counts the most recent N bars.",
     group = "Counter")
color  i_bandColor   = input.color(#ffffff, "Band color",            group = "Style · Lines & Ranges")
int    i_bandWidth   = input.int(1, "Band line width", minval = 1, maxval = 5,
     group = "Style · Lines & Ranges")
int    i_fillTransp  = input.int(90, "Range fill transparency", minval = 0, maxval = 100,
     group = "Style · Lines & Ranges")
color  i_strikeColor = input.color(color.red, "Short-put strike color",
     group = "Style · Lines & Ranges")
int    i_strikeWidth = input.int(1, "Strike line width", minval = 1, maxval = 5,
     group = "Style · Lines & Ranges")
color  i_cStrikeColor = input.color(color.orange, "Short-call strike color",
     group = "Style · Lines & Ranges")
color  i_winColor    = input.color(color.green, "Win marker color",
     group = "Style · Lines & Ranges")
color  i_lossColor   = input.color(color.rgb(188, 76, 76), "Loss marker color",
     group = "Style · Lines & Ranges")

color  i_tblText     = input.color(color.white, "Table text color",   group = "Style · Table")
color  i_tblHeaderBg = input.color(color.new(color.blue, 30), "Header background",  group = "Style · Table")
color  i_tblWinBg    = input.color(color.new(color.green, 50), "Win row background", group = "Style · Table")
color  i_tblLossBg   = input.color(color.new(color.red, 50), "Loss row background", group = "Style · Table")
color  i_tblNeutBg   = input.color(color.new(color.gray, 60), "Neutral row background", group = "Style · Table")
color  i_tblFrame    = input.color(color.gray, "Table frame/border color", group = "Style · Table")
string i_tblSize     = input.string("Normal", "Table text size",
     options = ["Tiny", "Small", "Normal", "Large"], group = "Style · Table")

print(txt) =>
    var lbl = label.new(bar_index, na, txt, xloc.bar_index, yloc.price, color(na), label.style_none, color.gray, size.large, text.align_left)
    label.set_xy(lbl, bar_index, ta.highest(10)[1])
    label.set_text(lbl, txt)

// ──────────────────────────────────────────────────────────────────────────────
// Expected move from VIX
// ──────────────────────────────────────────────────────────────────────────────
vixData = request.security("CBOE:VIX", timeframe.period, close)

scaleFreq = if timeframe.period == "D"
    math.sqrt(252)
else if timeframe.period == "W"
    math.sqrt(52)
else if timeframe.period == "M"
    math.sqrt(12)
else if timeframe.period == "15"
    math.sqrt(6552)
else if timeframe.period == "60"
    math.sqrt(1638)
else if timeframe.period == "120"
    math.sqrt(819)
else if timeframe.period == "240"
    math.sqrt(409)
else
    math.sqrt(252)

probPercMove = vixData / scaleFreq

changeUpper = close + (close * (probPercMove / 100))
changeLower = close - (close * (probPercMove / 100))

int projOff = i_projectFwd ? i_drift : 0

p1 = plot(changeUpper, 'Probable Upper Level', i_bandColor, linewidth = i_bandWidth, offset = projOff)
p2 = plot(changeLower, 'Probable Lower Level', i_bandColor, linewidth = i_bandWidth, offset = projOff)
fill(p1, p2, color = color.new(i_bandColor, i_fillTransp))

// ──────────────────────────────────────────────────────────────────────────────
// Trade engine
// Strike is FIXED at entry, anchored to the entry close; the expected move is
// scaled to the holding horizon (per-bar VIX move × sqrt(tenor bars)).
//   Overlapping  (i_everyBar): a trade is opened EVERY bar and resolved tenor
//                 bars later against its own fixed strike (trades overlap).
//   Non-overlap  : one trade at a time, rolled at expiry (independent samples).
// PCS win -> exit close ABOVE the fixed short-put strike
// CCS win -> exit close BELOW the fixed short-call strike
// ──────────────────────────────────────────────────────────────────────────────
withinLookback = i_lookback == 0 or (bar_index >= (last_bar_index - i_lookback + 1))

// expected % move over the whole holding window
emHold = probPercMove * math.sqrt(i_drift)

// strike a trade opened on THIS bar would carry (fixed, anchored to this close)
pOffNow = i_offsetMode  == "Points" ? i_offsetPts  : i_offsetMode  == "% of price" ? close * (i_offsetPct  / 100) : 0.0
cOffNow = i_cOffsetMode == "Points" ? i_cOffsetPts : i_cOffsetMode == "% of price" ? close * (i_cOffsetPct / 100) : 0.0
pStrikeNow = close * (1 - emHold / 100) - pOffNow
cStrikeNow = close * (1 + emHold / 100) + cOffNow

var int   cTotal   = 0
var int   cWin      = 0
var int   cTotalC  = 0
var int   cWinC     = 0
var float pHold    = na      // non-overlap: strike held flat for the trade
var float cHold    = na
var int   holdLeft = 0       // non-overlap: bars remaining until expiry

bool pcsWin  = false
bool pcsLoss = false
bool ccsWin  = false
bool ccsLoss = false

// Overlapping: resolve the trade that was opened i_drift bars ago.
ovResolvable = i_everyBar and barstate.isconfirmed and withinLookback and bar_index >= i_drift and not na(pStrikeNow[i_drift])
if ovResolvable
    pcsWin  := close >  pStrikeNow[i_drift]
    pcsLoss := close <= pStrikeNow[i_drift]
    cTotal  += 1
    cWin    += pcsWin ? 1 : 0
    if i_ccsEnable
        ccsWin  := close <  cStrikeNow[i_drift]
        ccsLoss := close >= cStrikeNow[i_drift]
        cTotalC += 1
        cWinC   += ccsWin ? 1 : 0

// Non-overlapping: one trade at a time, rolled at expiry.
if (not i_everyBar) and barstate.isconfirmed and withinLookback
    if holdLeft > 0
        holdLeft -= 1
        if holdLeft == 0
            pcsWin  := close >  pHold
            pcsLoss := close <= pHold
            cTotal  += 1
            cWin    += pcsWin ? 1 : 0
            if i_ccsEnable
                ccsWin  := close <  cHold
                ccsLoss := close >= cHold
                cTotalC += 1
                cWinC   += ccsWin ? 1 : 0
    if holdLeft == 0
        pHold    := pStrikeNow
        cHold    := cStrikeNow
        holdLeft := i_drift

int   plotOff     = i_everyBar ? i_drift : 0
float pStrikePlot = i_everyBar ? pStrikeNow : pHold
float cStrikePlot = i_everyBar ? cStrikeNow : cHold

plot(i_showStrike ? pStrikePlot : na, 'Short Put Strike', i_strikeColor,
     linewidth = i_strikeWidth, style = plot.style_linebr, offset = plotOff)
plot(i_ccsEnable and i_cShowStrike ? cStrikePlot : na, 'Short Call Strike', i_cStrikeColor,
     linewidth = i_strikeWidth, style = plot.style_linebr, offset = plotOff)

plotshape(i_showTrades and pcsWin,  title = "PCS win",
     style = shape.triangleup,   location = location.belowbar, color = i_winColor,  size = size.tiny)
plotshape(i_showTrades and pcsLoss, title = "PCS loss",
     style = shape.flag,         location = location.belowbar, color = i_lossColor, size = size.small)
plotshape(i_ccsEnable and i_cShowTrades and ccsWin,  title = "CCS win",
     style = shape.triangledown, location = location.abovebar, color = i_winColor,  size = size.tiny)
plotshape(i_ccsEnable and i_cShowTrades and ccsLoss, title = "CCS loss",
     style = shape.flag,         location = location.abovebar, color = i_lossColor, size = size.small)

cLoss    = cTotal - cWin
hitRate  = cTotal  > 0 ? (cWin  / cTotal)  * 100 : 0.0
cLossC   = cTotalC - cWinC
hitRateC = cTotalC > 0 ? (cWinC / cTotalC) * 100 : 0.0

// ──────────────────────────────────────────────────────────────────────────────
// Counter table
// ──────────────────────────────────────────────────────────────────────────────
tblPosition(p) =>
    p == "Top Right"     ? position.top_right    :
     p == "Top Left"     ? position.top_left     :
     p == "Bottom Right" ? position.bottom_right :
     p == "Bottom Left"  ? position.bottom_left  :
     p == "Middle Right" ? position.middle_right : position.middle_left

tblTextSize = i_tblSize == "Tiny"  ? size.tiny  :
              i_tblSize == "Small" ? size.small :
              i_tblSize == "Large" ? size.large : size.normal

f_num(v, enabled)  => enabled ? str.tostring(v) : "—"
f_rate(v, enabled) => enabled ? str.tostring(v, "#.##") + " %" : "—"

var table t = table.new(tblPosition(i_tblPos), 3, 5,
     border_width = 1, frame_color = i_tblFrame, frame_width = 1)

if i_showCounter and barstate.islast
    table.cell(t, 0, 0, str.tostring(timeframe.period), text_color = i_tblText, bgcolor = i_tblHeaderBg, text_size = tblTextSize)
    table.cell(t, 1, 0, "Put Credit",  text_color = i_tblText, bgcolor = i_tblHeaderBg, text_size = tblTextSize)
    table.cell(t, 2, 0, "Call Credit", text_color = i_tblText, bgcolor = i_tblHeaderBg, text_size = tblTextSize)

    table.cell(t, 0, 1, "Trades", text_color = i_tblText, bgcolor = i_tblNeutBg, text_size = tblTextSize)
    table.cell(t, 1, 1, f_num(cTotal,  true),         text_color = i_tblText, bgcolor = i_tblNeutBg, text_size = tblTextSize)
    table.cell(t, 2, 1, f_num(cTotalC, i_ccsEnable),  text_color = i_tblText, bgcolor = i_tblNeutBg, text_size = tblTextSize)

    table.cell(t, 0, 2, "Wins", text_color = i_tblText, bgcolor = i_tblWinBg, text_size = tblTextSize)
    table.cell(t, 1, 2, f_num(cWin,  true),         text_color = i_tblText, bgcolor = i_tblWinBg, text_size = tblTextSize)
    table.cell(t, 2, 2, f_num(cWinC, i_ccsEnable),  text_color = i_tblText, bgcolor = i_tblWinBg, text_size = tblTextSize)

    table.cell(t, 0, 3, "Losses", text_color = i_tblText, bgcolor = i_tblLossBg, text_size = tblTextSize)
    table.cell(t, 1, 3, f_num(cLoss,  true),        text_color = i_tblText, bgcolor = i_tblLossBg, text_size = tblTextSize)
    table.cell(t, 2, 3, f_num(cLossC, i_ccsEnable), text_color = i_tblText, bgcolor = i_tblLossBg, text_size = tblTextSize)

    table.cell(t, 0, 4, "Win rate", text_color = i_tblText, bgcolor = i_tblNeutBg, text_size = tblTextSize)
    table.cell(t, 1, 4, f_rate(hitRate,  true),        text_color = i_tblText, bgcolor = i_tblNeutBg, text_size = tblTextSize)
    table.cell(t, 2, 4, f_rate(hitRateC, i_ccsEnable), text_color = i_tblText, bgcolor = i_tblNeutBg, text_size = tblTextSize)

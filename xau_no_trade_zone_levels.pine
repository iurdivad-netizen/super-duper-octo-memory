//@version=5
indicator("UNDETECTED FX - No Trade Zone Levels", overlay=true, max_lines_count=500)

// -------- INPUTS --------
// Example (NQ): step = 100, level1 = 17080, level2 = 17120
// -> shades the 40-point band around every round 100 level (X80 to (X+1)20)
step       = input.float(100.0, "Repeat distance (price units)",      group="Levels")
level1     = input.float(17080.0, "First line level",                 group="Levels")
level2     = input.float(17120.0, "Second line level",                group="Levels")
maxLevel   = input.float(22000.0, "Highest level",                    group="Levels")
minLevel   = input.float(15000.0, "Lowest level",                     group="Levels")

lineColor  = input.color(color.new(color.black, 0), "Line color",        group="Style")
zoneColor  = input.color(color.new(color.red, 80),  "No-trade zone color", group="Style")
lineWidth  = input.int(2, "Line width", minval=1, maxval=5,              group="Style")

// -------- LEVEL COUNT --------
anchor1 = level1
anchor2 = level2

totalRange   = maxLevel - minLevel
repeatsCalc  = math.floor(totalRange / step) + 1
repeatCount  = math.min(repeatsCalc, 200)

// Start index so the first repetition lands at or just below minLevel
startOffset  = math.floor((minLevel - math.min(anchor1, anchor2)) / step)

// -------- ARRAYS --------
var line[] line1s = array.new_line()
var line[] line2s = array.new_line()
var linefill[] fills = array.new_linefill()

// -------- INIT: draw everything once --------
if barstate.isfirst
    for i = 0 to repeatCount - 1
        float offset = (startOffset + i) * step
        float lvl1   = anchor1 + offset
        float lvl2   = anchor2 + offset

        if lvl1 <= maxLevel and lvl2 <= maxLevel and lvl1 >= minLevel and lvl2 >= minLevel
            // Two horizontal lines that bound the no-trade zone
            l1 = line.new(0, lvl1, 1, lvl1, xloc=xloc.bar_index, extend=extend.both, color=lineColor, width=lineWidth)
            l2 = line.new(0, lvl2, 1, lvl2, xloc=xloc.bar_index, extend=extend.both, color=lineColor, width=lineWidth)

            // Fill between the two lines = no-trade zone
            f = linefill.new(l1, l2, color=zoneColor)

            array.push(line1s, l1)
            array.push(line2s, l2)
            array.push(fills, f)

// No update needed: lines are fixed at price and use extend.both

//@version=5
strategy("Initial Balance – Breakout & Retest [SP500/NQ]",
         overlay=true,
         default_qty_type=strategy.percent_of_equity,
         default_qty_value=10,
         commission_type=strategy.commission.percent,
         commission_value=0.01,
         slippage=2,
         calc_on_every_tick=false)

// ═══════════════════════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════════════════════

grpIB       = "Initial Balance"
grpEntry    = "Entry / Filter"
grpSL       = "Stop Loss"
grpTP       = "Take Profit"
grpDisplay  = "Display"

// IB window — fixed 9:30–10:30 EST for SP500/NQ
ibSession   = input.session("0930-1030", "IB Window (Exchange TZ)", group=grpIB,
                 tooltip="Keep default for NYSE/NASDAQ (EST). Adjust for futures sessions.")

// Entry
entryMode   = input.string("Break & Retest", "Entry Mode",
                 options=["Breakout", "Break & Retest", "Both"], group=grpEntry,
                 tooltip="Breakout: enter on the first confirmed close beyond the IB level.\nBreak & Retest: wait for price to pull away then return and hold the level.\nBoth: take whichever signal comes first each day.")
retestPct   = input.float(2.0,  "Retest Tolerance (% of IB Range)", minval=0.1, maxval=10.0, step=0.1, group=grpEntry,
                 tooltip="How close price must return to IB High/Low to arm the retest. 2% of a 100-pt range = 2 pts.")
confirmBars = input.int(1,  "Breakout Confirmation Candles", minval=1, maxval=3, group=grpEntry,
                 tooltip="Number of consecutive closes beyond the IB level required to confirm a breakout.")
tradeDir    = input.string("Both", "Direction", options=["Both", "Long Only", "Short Only"], group=grpEntry)
maxTradesDay= input.int(1, "Max Trades per Day", minval=1, maxval=4, group=grpEntry)

// Stop Loss
slMode      = input.string("IB Mid", "Stop Loss Mode", options=["IB Mid", "Swing High/Low", "Full IB Range"], group=grpSL,
                 tooltip="IB Mid: stop at midpoint of range.\nSwing High/Low: nearest pivot within lookback.\nFull IB Range: stop at opposite boundary.")
swingLookback = input.int(10, "Swing Lookback (bars)", minval=3, maxval=30, group=grpSL)
slBufferPct = input.float(0.05, "SL Buffer (% of IB Range)", minval=0.0, maxval=1.0, step=0.01, group=grpSL)

// Take Profit
tpMode      = input.string("1:2 RR", "Take Profit Mode", options=["1:2 RR", "1:3 RR", "+1R Ext", "+1.5R Ext", "+2R Ext", "+3R Ext"], group=grpTP)
useTrailStop= input.bool(false, "Use Trailing Stop after 1R", group=grpTP)

// Display
showIB      = input.bool(true,  "Show IB Range",          group=grpDisplay)
showMid     = input.bool(true,  "Show IB Midpoint",       group=grpDisplay)
showExts    = input.bool(true,  "Show IB Extensions",     group=grpDisplay)
showBG      = input.bool(true,  "Highlight IB Window",    group=grpDisplay)
showLabels  = input.bool(true,  "Show Level Labels",      group=grpDisplay)

// ═══════════════════════════════════════════════════════════════════════════════
// SESSION HELPERS
// ═══════════════════════════════════════════════════════════════════════════════

isIBBar     = not na(time("", ibSession))
isNewDay    = ta.change(time("D")) != 0
isRTH       = not na(time("", "0930-1600"))   // regular trading hours gate

// ═══════════════════════════════════════════════════════════════════════════════
// INITIAL BALANCE CALCULATION
// ═══════════════════════════════════════════════════════════════════════════════

var float ibHigh     = na
var float ibLow      = na
var float ibMid      = na
var float ibRange    = na
var bool  ibComplete = false
var bool  ibActive   = false    // currently inside IB window

if isNewDay
    ibHigh     := na
    ibLow      := na
    ibMid      := na
    ibRange    := na
    ibComplete := false
    ibActive   := false

if isIBBar
    ibActive := true
    ibHigh   := na(ibHigh) ? high : math.max(ibHigh, high)
    ibLow    := na(ibLow)  ? low  : math.min(ibLow,  low)

// Seal the IB on first bar after the window closes
if ibActive and not isIBBar and not ibComplete
    ibComplete := true
    ibMid      := (ibHigh + ibLow) / 2.0
    ibRange    := ibHigh - ibLow

// ═══════════════════════════════════════════════════════════════════════════════
// EXTENSIONS  (multiples of the IB range above High / below Low)
// ═══════════════════════════════════════════════════════════════════════════════

ext(mult, dir) =>
    ibComplete ? (dir > 0 ? ibHigh + ibRange * mult : ibLow - ibRange * mult) : na

ibExt1Up  = ext(1.0, 1)
ibExt15Up = ext(1.5, 1)
ibExt2Up  = ext(2.0, 1)
ibExt3Up  = ext(3.0, 1)
ibExt1Dn  = ext(1.0, -1)
ibExt15Dn = ext(1.5, -1)
ibExt2Dn  = ext(2.0, -1)
ibExt3Dn  = ext(3.0, -1)

// ═══════════════════════════════════════════════════════════════════════════════
// TRADE STATE  —  separate state machines for LONG and SHORT sides
// ═══════════════════════════════════════════════════════════════════════════════

// Each side progresses through phases:
//   0 → Breakout confirmed  (longBroke / shortBroke)
//   1 → Pulled away from level  (longPulledAway / shortPulledAway)
//       price makes at least one close > ibHigh + tolerance  (or < ibLow - tolerance)
//   2 → Retest armed  (longRetestArmed / shortRetestArmed)
//       price returns: low ≤ ibHigh + tolerance  (or high ≥ ibLow - tolerance)
//   3 → Retest confirmed on next close back beyond the level  → entry signal

var int   longCount        = 0      // consecutive closes above IB High
var int   shortCount       = 0      // consecutive closes below IB Low
var bool  longBroke        = false  // breakout confirmed
var bool  shortBroke       = false
var bool  longPulledAway   = false  // at least one close well above IB High after break
var bool  shortPulledAway  = false
var bool  longRetestArmed  = false  // price has returned to IB High ± tolerance
var bool  shortRetestArmed = false
var bool  longFired        = false  // a trade has been taken this day (long side)
var bool  shortFired       = false
var int   tradesToday      = 0

if isNewDay
    longCount        := 0
    shortCount       := 0
    longBroke        := false
    shortBroke       := false
    longPulledAway   := false
    shortPulledAway  := false
    longRetestArmed  := false
    shortRetestArmed := false
    longFired        := false
    shortFired       := false
    tradesToday      := 0

tolerance = ibComplete ? ibRange * (retestPct / 100.0) : na

if ibComplete and not isIBBar and not na(tolerance)

    // ── Breakout detection ───────────────────────────────────────────────────
    if not longBroke
        longCount := close > ibHigh ? longCount + 1 : 0
        if longCount >= confirmBars
            longBroke := true

    if not shortBroke
        shortCount := close < ibLow ? shortCount + 1 : 0
        if shortCount >= confirmBars
            shortBroke := true

    // ── Retest state machine  (runs only after breakout confirmed) ───────────

    // LONG: track pull-away then retest
    if longBroke and not longFired
        if not longPulledAway
            // require at least one close meaningfully above IB High
            if close > ibHigh + tolerance
                longPulledAway := true
        else if not longRetestArmed
            // armed when price drops back to touch the IB High zone
            if low <= ibHigh + tolerance
                longRetestArmed := true

    // SHORT: symmetric
    if shortBroke and not shortFired
        if not shortPulledAway
            if close < ibLow - tolerance
                shortPulledAway := true
        else if not shortRetestArmed
            if high >= ibLow - tolerance
                shortRetestArmed := true

// ─── One-bar entry signals ────────────────────────────────────────────────────

// Breakout signal: fires on the exact bar where breakout is first confirmed
longBreakoutBar  = ibComplete and not isIBBar and longBroke  and not longBroke[1]  and not longFired
shortBreakoutBar = ibComplete and not isIBBar and shortBroke and not shortBroke[1] and not shortFired

// Retest signal: armed AND this bar's close holds back above (long) / below (short) IB level
longRetestBar  = ibComplete and not isIBBar and longRetestArmed  and not longFired  and
                 close > ibHigh - tolerance * 0.25

shortRetestBar = ibComplete and not isIBBar and shortRetestArmed and not shortFired and
                 close < ibLow  + tolerance * 0.25

// Gate each signal by the selected entry mode
useBreakout = entryMode == "Breakout"      or entryMode == "Both"
useRetest   = entryMode == "Break & Retest" or entryMode == "Both"

longBreakoutSignal  = longBreakoutBar  and useBreakout
shortBreakoutSignal = shortBreakoutBar and useBreakout
longRetestSignal    = longRetestBar    and useRetest
shortRetestSignal   = shortRetestBar   and useRetest

// ─── Stop Loss calculation ────────────────────────────────────────────────────

swingLow_  = ta.lowest(low,  swingLookback)
swingHigh_ = ta.highest(high, swingLookback)
slBuffer   = ibComplete ? ibRange * (slBufferPct / 100.0) : na

// For a breakout long the natural SL is just below the broken level (IB High).
// For a retest long the broken level is already acting as support, so IB Mid or
// swing low are the logical reference points.
calcLongSL(entryPrice, isBreakout) =>
    base = isBreakout ? ibHigh : switch slMode
        "IB Mid"         => ibMid
        "Swing High/Low" => math.min(swingLow_, ibMid)
        "Full IB Range"  => ibLow
        => ibMid
    math.min(base, entryPrice) - slBuffer

calcShortSL(entryPrice, isBreakout) =>
    base = isBreakout ? ibLow : switch slMode
        "IB Mid"         => ibMid
        "Swing High/Low" => math.max(swingHigh_, ibMid)
        "Full IB Range"  => ibHigh
        => ibMid
    math.max(base, entryPrice) + slBuffer

// ─── Take Profit calculation ──────────────────────────────────────────────────

calcTP(entryPrice, sl, isLong) =>
    risk = math.abs(entryPrice - sl)
    dir  = isLong ? 1.0 : -1.0
    switch tpMode
        "1:2 RR"    => entryPrice + dir * risk * 2.0
        "1:3 RR"    => entryPrice + dir * risk * 3.0
        "+1R Ext"   => isLong ? ibExt1Up  : ibExt1Dn
        "+1.5R Ext" => isLong ? ibExt15Up : ibExt15Dn
        "+2R Ext"   => isLong ? ibExt2Up  : ibExt2Dn
        "+3R Ext"   => isLong ? ibExt3Up  : ibExt3Dn
        => entryPrice + dir * risk * 2.0

// ═══════════════════════════════════════════════════════════════════════════════
// ENTRY ORDERS
// ═══════════════════════════════════════════════════════════════════════════════

canLong  = tradeDir != "Short Only"
canShort = tradeDir != "Long Only"
slotOpen = strategy.position_size == 0 and tradesToday < maxTradesDay and isRTH

// ── Long breakout entry ───────────────────────────────────────────────────────
if longBreakoutSignal and canLong and slotOpen
    entryP = close
    sl     = calcLongSL(entryP, true)
    tp     = calcTP(entryP, sl, true)
    if tp > entryP and sl < entryP
        strategy.entry("Long BO", strategy.long)
        strategy.exit("Long BO Exit", "Long BO",
             stop         = sl,
             limit        = tp,
             trail_price  = useTrailStop ? entryP + math.abs(entryP - sl) : na,
             trail_offset = useTrailStop ? math.abs(entryP - sl) * syminfo.mintick * 10 : na)
        longFired   := true
        tradesToday += 1

// ── Long retest entry ─────────────────────────────────────────────────────────
if longRetestSignal and canLong and slotOpen
    entryP = close
    sl     = calcLongSL(entryP, false)
    tp     = calcTP(entryP, sl, true)
    if tp > entryP and sl < entryP
        strategy.entry("Long RT", strategy.long)
        strategy.exit("Long RT Exit", "Long RT",
             stop         = sl,
             limit        = tp,
             trail_price  = useTrailStop ? entryP + math.abs(entryP - sl) : na,
             trail_offset = useTrailStop ? math.abs(entryP - sl) * syminfo.mintick * 10 : na)
        longFired   := true
        tradesToday += 1

// ── Short breakout entry ──────────────────────────────────────────────────────
if shortBreakoutSignal and canShort and slotOpen
    entryP = close
    sl     = calcShortSL(entryP, true)
    tp     = calcTP(entryP, sl, false)
    if tp < entryP and sl > entryP
        strategy.entry("Short BO", strategy.short)
        strategy.exit("Short BO Exit", "Short BO",
             stop         = sl,
             limit        = tp,
             trail_price  = useTrailStop ? entryP - math.abs(entryP - sl) : na,
             trail_offset = useTrailStop ? math.abs(entryP - sl) * syminfo.mintick * 10 : na)
        shortFired  := true
        tradesToday += 1

// ── Short retest entry ────────────────────────────────────────────────────────
if shortRetestSignal and canShort and slotOpen
    entryP = close
    sl     = calcShortSL(entryP, false)
    tp     = calcTP(entryP, sl, false)
    if tp < entryP and sl > entryP
        strategy.entry("Short RT", strategy.short)
        strategy.exit("Short RT Exit", "Short RT",
             stop         = sl,
             limit        = tp,
             trail_price  = useTrailStop ? entryP - math.abs(entryP - sl) : na,
             trail_offset = useTrailStop ? math.abs(entryP - sl) * syminfo.mintick * 10 : na)
        shortFired  := true
        tradesToday += 1

// ═══════════════════════════════════════════════════════════════════════════════
// PLOTS
// ═══════════════════════════════════════════════════════════════════════════════

// IB background highlight
bgcolor(showBG and isIBBar ? color.new(color.orange, 88) : na, title="IB Window")

// Core IB levels
plotIBH = (showIB and (ibActive or ibComplete)) ? ibHigh : na
plotIBL = (showIB and (ibActive or ibComplete)) ? ibLow  : na
plotIBM = (showMid and ibComplete) ? ibMid : na

pIBH = plot(plotIBH, "IB High", color=color.new(color.orange, 0),  linewidth=2, style=plot.style_linebr)
pIBL = plot(plotIBL, "IB Low",  color=color.new(color.orange, 0),  linewidth=2, style=plot.style_linebr)
plot(plotIBM,        "IB Mid",  color=color.new(color.yellow, 20), linewidth=1, style=plot.style_linebr)

// Fill between IB High and Low
fill(pIBH, pIBL, color=color.new(color.orange, 92), title="IB Range Fill")

// Extensions
cGreen = color.new(color.lime,  0)
cRed   = color.new(color.red,   0)

plot(showExts ? ibExt1Up  : na, "+1R",   color=color.new(cGreen, 40), linewidth=1, style=plot.style_linebr)
plot(showExts ? ibExt15Up : na, "+1.5R", color=color.new(cGreen, 55), linewidth=1, style=plot.style_linebr)
plot(showExts ? ibExt2Up  : na, "+2R",   color=color.new(cGreen, 30), linewidth=1, style=plot.style_linebr)
plot(showExts ? ibExt3Up  : na, "+3R",   color=color.new(cGreen, 20), linewidth=1, style=plot.style_linebr)
plot(showExts ? ibExt1Dn  : na, "-1R",   color=color.new(cRed,   40), linewidth=1, style=plot.style_linebr)
plot(showExts ? ibExt15Dn : na, "-1.5R", color=color.new(cRed,   55), linewidth=1, style=plot.style_linebr)
plot(showExts ? ibExt2Dn  : na, "-2R",   color=color.new(cRed,   30), linewidth=1, style=plot.style_linebr)
plot(showExts ? ibExt3Dn  : na, "-3R",   color=color.new(cRed,   20), linewidth=1, style=plot.style_linebr)

// ── Breakout entry signals (filled triangle = trade fires here)
plotshape(longBreakoutSignal  and canLong  and slotOpen, "Long Breakout",  shape.triangleup,   location.belowbar, color.new(color.lime,  0), size=size.small, title="Long Breakout Entry")
plotshape(shortBreakoutSignal and canShort and slotOpen, "Short Breakout", shape.triangledown, location.abovebar, color.new(color.red,   0), size=size.small, title="Short Breakout Entry")

// ── Retest entry signals (circle = trade fires here)
plotshape(longRetestSignal  and canLong  and slotOpen, "Long Retest",  shape.circle, location.belowbar, color.new(color.aqua, 0), size=size.small, title="Long Retest Entry")
plotshape(shortRetestSignal and canShort and slotOpen, "Short Retest", shape.circle, location.abovebar, color.new(color.fuchsia, 0), size=size.small, title="Short Retest Entry")

// ── State markers (no fill = informational only, no trade)
plotshape(ibComplete and longBroke  and not longBroke[1]  and not longFired,  "Long Break Confirmed",  shape.diamond, location.abovebar, color.new(color.lime, 60), size=size.tiny, title="Long Break Confirmed")
plotshape(ibComplete and shortBroke and not shortBroke[1] and not shortFired, "Short Break Confirmed", shape.diamond, location.belowbar, color.new(color.red,  60), size=size.tiny, title="Short Break Confirmed")
plotshape(ibComplete and longRetestArmed  and not longRetestArmed[1]  and not longFired,  "Long Retest Armed",  shape.xcross, location.belowbar, color.new(color.aqua,    50), size=size.tiny, title="Long Retest Armed")
plotshape(ibComplete and shortRetestArmed and not shortRetestArmed[1] and not shortFired, "Short Retest Armed", shape.xcross, location.abovebar, color.new(color.fuchsia, 50), size=size.tiny, title="Short Retest Armed")

// ═══════════════════════════════════════════════════════════════════════════════
// LEVEL LABELS  (drawn on the last bar of each day to avoid clutter)
// ═══════════════════════════════════════════════════════════════════════════════

if showLabels and ibComplete and barstate.islast
    lx = bar_index + 2
    labelStyle = label.style_label_left
    sz         = size.small

    label.new(lx, ibHigh,     "IB High  " + str.tostring(ibHigh, "#.##"),     color=color.new(color.orange,80), textcolor=color.orange, style=labelStyle, size=sz)
    label.new(lx, ibLow,      "IB Low   " + str.tostring(ibLow,  "#.##"),     color=color.new(color.orange,80), textcolor=color.orange, style=labelStyle, size=sz)
    label.new(lx, ibMid,      "IB Mid   " + str.tostring(ibMid,  "#.##"),     color=color.new(color.yellow,80), textcolor=color.yellow, style=labelStyle, size=sz)
    if showExts
        label.new(lx, ibExt1Up,  "+1R   "  + str.tostring(ibExt1Up,  "#.##"), color=color.new(color.green, 80), textcolor=color.lime,   style=labelStyle, size=sz)
        label.new(lx, ibExt2Up,  "+2R   "  + str.tostring(ibExt2Up,  "#.##"), color=color.new(color.green, 80), textcolor=color.lime,   style=labelStyle, size=sz)
        label.new(lx, ibExt3Up,  "+3R   "  + str.tostring(ibExt3Up,  "#.##"), color=color.new(color.green, 80), textcolor=color.lime,   style=labelStyle, size=sz)
        label.new(lx, ibExt1Dn,  "-1R   "  + str.tostring(ibExt1Dn,  "#.##"), color=color.new(color.red,   80), textcolor=color.red,    style=labelStyle, size=sz)
        label.new(lx, ibExt2Dn,  "-2R   "  + str.tostring(ibExt2Dn,  "#.##"), color=color.new(color.red,   80), textcolor=color.red,    style=labelStyle, size=sz)
        label.new(lx, ibExt3Dn,  "-3R   "  + str.tostring(ibExt3Dn,  "#.##"), color=color.new(color.red,   80), textcolor=color.red,    style=labelStyle, size=sz)

// ═══════════════════════════════════════════════════════════════════════════════
// INFO TABLE
// ═══════════════════════════════════════════════════════════════════════════════

var table t = table.new(position.top_right, 2, 9,
     bgcolor=color.new(color.black, 60), border_width=1, border_color=color.new(color.gray, 50))

tCol0 = color.new(color.silver, 0)
tCol1 = color.new(color.orange, 0)
bg    = color.new(color.black, 70)

if barstate.islast
    table.cell(t, 0, 0, "IB Range",   text_color=tCol0, text_size=size.small, bgcolor=bg)
    table.cell(t, 1, 0, ibComplete ? str.tostring(math.round(ibRange * 100) / 100) : "building…",
               text_color=tCol1, text_size=size.small, bgcolor=bg)

    table.cell(t, 0, 1, "IB High",    text_color=tCol0, text_size=size.small, bgcolor=bg)
    table.cell(t, 1, 1, ibComplete ? str.tostring(math.round(ibHigh * 100) / 100) : "—",
               text_color=tCol1, text_size=size.small, bgcolor=bg)

    table.cell(t, 0, 2, "IB Low",     text_color=tCol0, text_size=size.small, bgcolor=bg)
    table.cell(t, 1, 2, ibComplete ? str.tostring(math.round(ibLow  * 100) / 100) : "—",
               text_color=tCol1, text_size=size.small, bgcolor=bg)

    table.cell(t, 0, 3, "IB Mid",     text_color=tCol0, text_size=size.small, bgcolor=bg)
    table.cell(t, 1, 3, ibComplete ? str.tostring(math.round(ibMid  * 100) / 100) : "—",
               text_color=color.yellow, text_size=size.small, bgcolor=bg)

    table.cell(t, 0, 4, "Entry Mode", text_color=tCol0, text_size=size.small, bgcolor=bg)
    table.cell(t, 1, 4, entryMode,    text_color=color.aqua, text_size=size.small, bgcolor=bg)

    table.cell(t, 0, 5, "Direction",  text_color=tCol0, text_size=size.small, bgcolor=bg)
    table.cell(t, 1, 5, tradeDir,     text_color=color.aqua, text_size=size.small, bgcolor=bg)

    table.cell(t, 0, 6, "TP Mode",    text_color=tCol0, text_size=size.small, bgcolor=bg)
    table.cell(t, 1, 6, tpMode,       text_color=color.aqua, text_size=size.small, bgcolor=bg)

    // Long phase
    longPhase = not ibComplete ? "pre-IB" : not longBroke ? "watching" : not longPulledAway ? "broke – pull away" : not longRetestArmed ? "pulled – retest?" : longFired ? "fired" : "retest armed"
    table.cell(t, 0, 7, "Long Phase", text_color=tCol0, text_size=size.small, bgcolor=bg)
    table.cell(t, 1, 7, longPhase,    text_color=longFired ? color.lime : longRetestArmed ? color.aqua : longBroke ? color.yellow : color.gray, text_size=size.small, bgcolor=bg)

    // Short phase
    shortPhase = not ibComplete ? "pre-IB" : not shortBroke ? "watching" : not shortPulledAway ? "broke – pull away" : not shortRetestArmed ? "pulled – retest?" : shortFired ? "fired" : "retest armed"
    table.cell(t, 0, 8, "Short Phase", text_color=tCol0,  text_size=size.small, bgcolor=bg)
    table.cell(t, 1, 8, shortPhase,    text_color=shortFired ? color.red : shortRetestArmed ? color.fuchsia : shortBroke ? color.yellow : color.gray, text_size=size.small, bgcolor=bg)

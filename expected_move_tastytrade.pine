// ──────────────────────────────────────────────────────────────────────────────
// EXPECTED MOVE (tastytrade)  —  manual-feed expected-move bands
// ──────────────────────────────────────────────────────────────────────────────
// Plots tastytrade's expected move as upper/lower bands around an anchor price.
//
// WHY MANUAL INPUT:
//   Pine Script runs in TradingView's sandbox and cannot call external APIs, so
//   it cannot pull from tastytrade directly. tastytrade derives the expected
//   move from the live option chain (≈ the ATM straddle for an expiration). You
//   read that value off tastytrade and paste it here; this indicator handles the
//   N-day (DTE) scaling and draws the bands. Sibling indicator
//   `spx_expected_move_vix.pine` derives the move from VIX because VIX *is* a
//   TradingView feed — tastytrade is not.
//
// TWO WAYS TO FEED IT (input "Expected move source"):
//   • "Points"  — paste tastytrade's expected move directly in points of the
//                 underlying (e.g. ±72). Tell it which expiration that value is
//                 for (Source DTE) and the indicator rescales it to your Target
//                 DTE by √(targetDTE / sourceDTE).
//   • "ATM IV %"— paste the at-the-money implied volatility (e.g. 18.5). The
//                 move is computed as  EM = price × IV × √(DTE / 365).
//
// EXPECTED MOVE SCALES WITH √TIME, so an EM for one horizon is converted to any
// other horizon by the square-root-of-time rule. A 1σ move (~68% of outcomes)
// is the default; raise the multiplier or enable the 2nd band for a 2σ (~95%)
// envelope.
//
// LOCK TO A DATE (Anchor = "Locked date"):
//   Pick a day/time; the anchor price is captured from that day's bar and the
//   bands run flat from there forward (no redraw across prior history). Use this
//   to pin the expected-move range to the day you read tastytrade. Set a fixed
//   entry price to override the auto-captured anchor.
//
// A "valid as of" label is drawn at the last bar so a stale pasted value is
// obvious. Re-read tastytrade and update the inputs when it drifts.

//@version=5

indicator(title = "Expected Move (tastytrade)", shorttitle = "Exp Move (TT)", overlay = true)

// ──────────────────────────────────────────────────────────────────────────────
// Inputs · Expected move
// ──────────────────────────────────────────────────────────────────────────────
string i_source     = input.string("Points", "Expected move source",
     options = ["Points", "ATM IV %"],
     tooltip = "Points: paste tastytrade's expected move in points. ATM IV %: paste the at-the-money implied volatility and let the indicator compute the move.",
     group = "Expected move")

float  i_emPoints   = input.float(50.0, "  ↳ Expected move (points)",
     minval = 0.0, step = 1.0,
     tooltip = "Used when source = Points. The ± expected move tastytrade shows, in points of the underlying.",
     group = "Expected move")
int    i_srcDTE     = input.int(1, "  ↳ that value's expiration (Source DTE)",
     minval = 1,
     tooltip = "Days-to-expiration of the tastytrade value you pasted above. The move is rescaled from this horizon to the Target DTE by √(target / source). Set equal to Target DTE to plot the pasted value as-is.",
     group = "Expected move")

float  i_ivPct      = input.float(18.0, "  ↳ ATM implied volatility (%)",
     minval = 0.0, step = 0.5,
     tooltip = "Used when source = ATM IV %. Annualized at-the-money IV in percent, e.g. 18.5.",
     group = "Expected move")

int    i_dte        = input.int(1, "Target horizon (DTE, days)",
     minval = 1,
     tooltip = "The N days you want the expected move for. Points mode rescales the pasted value to this horizon; IV mode computes EM = price × IV × √(DTE/365).",
     group = "Expected move")

float  i_mult       = input.float(1.0, "Band multiplier (σ)",
     minval = 0.1, step = 0.1,
     tooltip = "1.0 = one standard deviation (~68% of outcomes), tastytrade's default expected move. 2.0 = ~95%.",
     group = "Expected move")

// ──────────────────────────────────────────────────────────────────────────────
// Inputs · Anchor
// ──────────────────────────────────────────────────────────────────────────────
string i_anchorMode = input.string("Chart price", "Anchor",
     options = ["Chart price", "Fixed entry price", "Locked date"],
     tooltip = "Chart price: bands re-center on the current close each bar. Fixed entry price: flat bands around a price you specify. Locked date: anchor to the price on a chosen day and draw the bands flat from that day forward.",
     group = "Anchor")
float  i_entryPrice = input.float(0.0, "  ↳ Fixed / lock entry price (0 = auto)",
     minval = 0.0, step = 0.25,
     tooltip = "The underlying price the expected move was quoted against. Used directly in Fixed entry price mode. In Locked date mode, 0 = auto-capture the price on the lock day; a value > 0 overrides it.",
     group = "Anchor")
bool   i_projectFwd = input.bool(true, "Project bands forward by the horizon",
     tooltip = "Shifts the bands right by Target DTE bars so the envelope sits over the bar the move resolves on. Visual only.",
     group = "Anchor")
bool   i_extendOn   = input.bool(false, "Extend bands into the future",
     tooltip = "Push the bands out beyond the last/current bar by a fixed number of bars (in addition to any horizon projection). Best with a Fixed or Locked anchor so the extended lines stay flat.",
     group = "Anchor")
int    i_extendBars = input.int(20, "  ↳ by X bars", minval = 1,
     tooltip = "How many bars past the last bar to extend the bands when the toggle above is on.",
     group = "Anchor")

// ── Lock to date ──
int    i_lockTime   = input.time(timestamp("2026-01-01T00:00:00"), "Lock date/time",
     tooltip = "Used when Anchor = Locked date. The bands start here and run forward. The anchor price is captured from the first bar at/after this moment (unless overridden above).",
     group = "Anchor")
string i_lockSrc    = input.string("Open", "  ↳ price captured on lock day",
     options = ["Open", "Close", "HL2"],
     tooltip = "Which price of the lock bar to anchor to when auto-capturing (entry price = 0).",
     group = "Anchor")

// ──────────────────────────────────────────────────────────────────────────────
// Inputs · Second band
// ──────────────────────────────────────────────────────────────────────────────
bool   i_band2On    = input.bool(false, "Show second band",
     tooltip = "Draw an additional envelope at a different multiplier (e.g. 2σ).",
     group = "Second band")
float  i_mult2      = input.float(2.0, "  ↳ second band multiplier (σ)",
     minval = 0.1, step = 0.1, group = "Second band")

// ── Quarter levels ──
bool   i_quarters   = input.bool(false, "Show 25 / 50 / 75% levels",
     tooltip = "Master switch for the intermediate guide lines at 25%, 50% and 75% of the expected-move range on each side of the anchor. Toggle individual levels below to cut clutter.",
     group = "Quarter levels")
bool   i_q25        = input.bool(true, "  ↳ 25% level", group = "Quarter levels")
bool   i_q50        = input.bool(true, "  ↳ 50% level", group = "Quarter levels")
bool   i_q75        = input.bool(true, "  ↳ 75% level", group = "Quarter levels")
string i_qScope     = input.string("σ1", "Levels relative to",
     options = ["σ1", "σ2"],
     tooltip = "Whether the 25/50/75% levels are fractions of the σ1 band or the σ2 band.",
     group = "Quarter levels")
color  i_qColor     = input.color(color.new(#26a69a, 35), "Level color", group = "Quarter levels")
int    i_qWidth     = input.int(1, "Level line width", minval = 1, maxval = 3, group = "Quarter levels")

// ──────────────────────────────────────────────────────────────────────────────
// Inputs · Label & style
// ──────────────────────────────────────────────────────────────────────────────
bool   i_showLabel  = input.bool(true, "Show info box", group = "Info box")
string i_infoMode   = input.string("Follow price", "Placement",
     options = ["Follow price", "Corner"],
     tooltip = "Follow price: the box sits at the band edge on the last bar. Corner: the box is pinned to a fixed corner of the chart.",
     group = "Info box")
string i_infoPos    = input.string("Top Right", "  ↳ corner",
     options = ["Top Right", "Top Left", "Bottom Right", "Bottom Left", "Middle Right", "Middle Left"],
     tooltip = "Used when Placement = Corner.",
     group = "Info box")
string i_infoSize   = input.string("Normal", "Text size",
     options = ["Tiny", "Small", "Normal", "Large"], group = "Info box")
color  i_labelColor = input.color(color.new(color.gray, 20), "Background color", group = "Info box")
color  i_labelText  = input.color(color.white, "Text color", group = "Info box")
string i_asOf       = input.string("", "Value read on (free text)",
     tooltip = "Optional note shown in the info box, e.g. the date/time you read the value off tastytrade. Stale values are easy to miss otherwise.",
     group = "Info box")
bool   i_priceTags  = input.bool(true, "Show price at each band edge",
     tooltip = "Prints the price of the upper/lower band (and σ2 band when enabled) at the right end of the lines.",
     group = "Band price tags")
bool   i_qTags      = input.bool(false, "Show price at 25 / 50 / 75% levels",
     tooltip = "Adds price labels to whichever quarter levels are visible. Requires the quarter levels to be enabled.",
     group = "Band price tags")

color  i_bandColor  = input.color(#26a69a, "Band color", group = "Style")
int    i_bandWidth  = input.int(2, "Band line width", minval = 1, maxval = 5, group = "Style")
int    i_fillTransp = input.int(90, "Range fill transparency", minval = 0, maxval = 100, group = "Style")
color  i_band2Color = input.color(color.new(#26a69a, 40), "Second band color", group = "Style")
bool   i_shadeFut   = input.bool(true, "Shade future (no-price) zone",
     tooltip = "Fills the projected expected-move range over the empty area to the right of the last bar. Needs the horizon projection and/or future extension to be on so the zone has width.",
     group = "Future zone")
color  i_futZone1   = input.color(color.new(#26a69a, 78), "σ1 zone fill", group = "Future zone")
color  i_futZone2   = input.color(color.new(#26a69a, 88), "σ2 zone fill", group = "Future zone")

// ──────────────────────────────────────────────────────────────────────────────
// Expected move → points of the underlying
// ──────────────────────────────────────────────────────────────────────────────
lockMode  = i_anchorMode == "Locked date"
afterLock = time >= i_lockTime

// Capture the anchor price on the first bar at/after the lock moment, hold it.
lockSrcVal = i_lockSrc == "Close" ? close : i_lockSrc == "HL2" ? hl2 : open
var float lockedAnchor = na
if lockMode and na(lockedAnchor) and afterLock
    lockedAnchor := i_entryPrice > 0 ? i_entryPrice : lockSrcVal

anchorPrice = lockMode ? lockedAnchor :
     i_anchorMode == "Fixed entry price" and i_entryPrice > 0 ? i_entryPrice : close

// Bands only exist from the lock day forward (and once the anchor is captured).
bandOn = not lockMode or (afterLock and not na(lockedAnchor))

// base 1σ move at the target horizon, in points
emBase = if i_source == "Points"
    i_emPoints * math.sqrt(i_dte / math.max(i_srcDTE, 1))
else
    nz(anchorPrice) * (i_ivPct / 100.0) * math.sqrt(i_dte / 365.0)

em1 = emBase * i_mult
em2 = emBase * i_mult2

upper1 = bandOn ? anchorPrice + em1 : na
lower1 = bandOn ? anchorPrice - em1 : na
upper2 = bandOn ? anchorPrice + em2 : na
lower2 = bandOn ? anchorPrice - em2 : na

int projOff = (i_projectFwd ? i_dte : 0) + (i_extendOn ? i_extendBars : 0)

// ──────────────────────────────────────────────────────────────────────────────
// Plots
// ──────────────────────────────────────────────────────────────────────────────
p1u = plot(upper1, "Upper (σ1)", i_bandColor, linewidth = i_bandWidth, style = plot.style_linebr, offset = projOff)
p1l = plot(lower1, "Lower (σ1)", i_bandColor, linewidth = i_bandWidth, style = plot.style_linebr, offset = projOff)
fill(p1u, p1l, color = color.new(i_bandColor, i_fillTransp))

plot(i_band2On ? upper2 : na, "Upper (σ2)", i_band2Color, linewidth = i_bandWidth,
     style = plot.style_linebr, offset = projOff)
plot(i_band2On ? lower2 : na, "Lower (σ2)", i_band2Color, linewidth = i_bandWidth,
     style = plot.style_linebr, offset = projOff)

// ──────────────────────────────────────────────────────────────────────────────
// Quarter levels (25 / 50 / 75% of the chosen band) on each side of the anchor
// ──────────────────────────────────────────────────────────────────────────────
qEm   = i_qScope == "σ2" ? em2 : em1
qOn   = i_quarters and bandOn and (i_qScope == "σ1" or i_band2On)
qLvl(frac, show) => qOn and show ? anchorPrice + frac * qEm : na
plot(qLvl( 0.75, i_q75), "75% up",   i_qColor, linewidth = i_qWidth, style = plot.style_linebr, offset = projOff)
plot(qLvl( 0.50, i_q50), "50% up",   i_qColor, linewidth = i_qWidth, style = plot.style_linebr, offset = projOff)
plot(qLvl( 0.25, i_q25), "25% up",   i_qColor, linewidth = i_qWidth, style = plot.style_linebr, offset = projOff)
plot(qLvl(-0.25, i_q25), "25% down", i_qColor, linewidth = i_qWidth, style = plot.style_linebr, offset = projOff)
plot(qLvl(-0.50, i_q50), "50% down", i_qColor, linewidth = i_qWidth, style = plot.style_linebr, offset = projOff)
plot(qLvl(-0.75, i_q75), "75% down", i_qColor, linewidth = i_qWidth, style = plot.style_linebr, offset = projOff)

// ──────────────────────────────────────────────────────────────────────────────
// Future (no-price) projection zone — box over the empty area to the right
// ──────────────────────────────────────────────────────────────────────────────
var box fz1 = na
var box fz2 = na
if barstate.islast
    if not na(fz1)
        box.delete(fz1)
        fz1 := na
    if not na(fz2)
        box.delete(fz2)
        fz2 := na
    if i_shadeFut and bandOn and not na(anchorPrice) and projOff > 0
        int rX = last_bar_index + projOff
        if i_band2On
            fz2 := box.new(last_bar_index, anchorPrice + em2, rX, anchorPrice - em2,
                 border_width = 0, bgcolor = i_futZone2)
        fz1 := box.new(last_bar_index, anchorPrice + em1, rX, anchorPrice - em1,
             border_width = 0, bgcolor = i_futZone1)

// ──────────────────────────────────────────────────────────────────────────────
// "Valid as of" label
// ──────────────────────────────────────────────────────────────────────────────
// ──────────────────────────────────────────────────────────────────────────────
// Price tags at the right end of each band
// ──────────────────────────────────────────────────────────────────────────────
var label pt_u1 = na
var label pt_l1 = na
var label pt_u2 = na
var label pt_l2 = na
f_priceTag(_x, _y, _col) =>
    label.new(_x, _y, str.tostring(_y, format.mintick), xloc.bar_index, yloc.price,
         color.new(color.white, 100), label.style_label_left, _col, size.small)
if barstate.islast
    if not na(pt_u1)
        label.delete(pt_u1)
        pt_u1 := na
    if not na(pt_l1)
        label.delete(pt_l1)
        pt_l1 := na
    if not na(pt_u2)
        label.delete(pt_u2)
        pt_u2 := na
    if not na(pt_l2)
        label.delete(pt_l2)
        pt_l2 := na
    if i_priceTags and bandOn and not na(anchorPrice)
        int rX = last_bar_index + projOff
        pt_u1 := f_priceTag(rX, anchorPrice + em1, i_bandColor)
        pt_l1 := f_priceTag(rX, anchorPrice - em1, i_bandColor)
        if i_band2On
            pt_u2 := f_priceTag(rX, anchorPrice + em2, i_band2Color)
            pt_l2 := f_priceTag(rX, anchorPrice - em2, i_band2Color)

// price tags for the visible quarter levels
var array<label> qTags = array.new<label>()
if barstate.islast
    for lb in qTags
        label.delete(lb)
    array.clear(qTags)
    if i_qTags and qOn and not na(anchorPrice)
        int rX = last_bar_index + projOff
        if i_q75
            array.push(qTags, f_priceTag(rX, anchorPrice + 0.75 * qEm, i_qColor))
            array.push(qTags, f_priceTag(rX, anchorPrice - 0.75 * qEm, i_qColor))
        if i_q50
            array.push(qTags, f_priceTag(rX, anchorPrice + 0.50 * qEm, i_qColor))
            array.push(qTags, f_priceTag(rX, anchorPrice - 0.50 * qEm, i_qColor))
        if i_q25
            array.push(qTags, f_priceTag(rX, anchorPrice + 0.25 * qEm, i_qColor))
            array.push(qTags, f_priceTag(rX, anchorPrice - 0.25 * qEm, i_qColor))

f_pct(v) => str.tostring(v / anchorPrice * 100.0, "#.##") + "%"
f_size(s) => s == "Tiny" ? size.tiny : s == "Small" ? size.small : s == "Large" ? size.large : size.normal
f_pos(p)  => p == "Top Right"    ? position.top_right    :
     p == "Top Left"     ? position.top_left     :
     p == "Bottom Right" ? position.bottom_right :
     p == "Bottom Left"  ? position.bottom_left  :
     p == "Middle Right" ? position.middle_right : position.middle_left

var label infoLbl = na
var table infoTbl = na
if barstate.islast
    if not na(infoLbl)
        label.delete(infoLbl)
        infoLbl := na
    if not na(infoTbl)
        table.delete(infoTbl)
        infoTbl := na
    if i_showLabel
        srcTxt = i_source == "Points"
             ? "EM " + str.tostring(i_emPoints, "#.##") + " pts @ " + str.tostring(i_srcDTE) + " DTE"
             : "ATM IV " + str.tostring(i_ivPct, "#.##") + "%"
        lockTxt = lockMode ? "\nLocked: " + str.format_time(i_lockTime, "yyyy-MM-dd HH:mm", "GMT") : ""
        txt = if lockMode and na(anchorPrice)
            "Expected Move (tastytrade)\n" + srcTxt +
                 "\nWaiting for lock date…" + lockTxt
        else
            "Expected Move (tastytrade)\n" +
                 srcTxt + lockTxt + "\n" +
                 "Horizon: " + str.tostring(i_dte) + " DTE   ×" + str.tostring(i_mult, "#.##") + "σ\n" +
                 "Anchor: " + str.tostring(anchorPrice, format.mintick) + "\n" +
                 "Move: ±" + str.tostring(em1, "#.##") + " pts  (±" + f_pct(em1) + ")\n" +
                 "Range: " + str.tostring(anchorPrice - em1, format.mintick) + " – " + str.tostring(anchorPrice + em1, format.mintick) +
                 (str.length(i_asOf) > 0 ? "\nValid as of: " + i_asOf : "")
        if i_infoMode == "Corner"
            infoTbl := table.new(f_pos(i_infoPos), 1, 1, border_width = 0)
            table.cell(infoTbl, 0, 0, txt, text_color = i_labelText, bgcolor = i_labelColor,
                 text_size = f_size(i_infoSize), text_halign = text.align_left)
        else
            labelY = not na(upper1) ? upper1 : not na(anchorPrice) ? anchorPrice : close
            infoLbl := label.new(last_bar_index + projOff, labelY, txt, xloc.bar_index, yloc.price,
                 i_labelColor, label.style_label_down, i_labelText, f_size(i_infoSize), text.align_left)
